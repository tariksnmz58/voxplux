<ui:FluentWindow x:Class="Voxplux.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Voxplux.App.ViewModels"
        xmlns:conv="clr-namespace:Voxplux.App.Converters"
        Title="Voxplux" Width="1100" Height="700"
        MinWidth="900" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:VolumeToPercentConverter x:Key="VolToPercent"/>
        <conv:GainToStringConverter x:Key="GainToStr"/>
        <conv:ActiveToBrushConverter x:Key="ActiveToBrush"/>
        <conv:SelectedToBorderConverter x:Key="SelToBorder"/>
        <conv:SelectedToBorderBrushConverter x:Key="SelToBorderBrush"/>
        <conv:DelayToStringConverter x:Key="DelayToStr"/>
    </Window.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="Multi-Connect Sound" ShowMaximize="True" ShowMinimize="True">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="🎧" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Voxplux" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}"
                    CornerRadius="16" BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" Margin="0,0,8,0" Effect="{DynamicResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="20,16,20,4">
                        <TextBlock Text="Cihaz Havuzu" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Anahtarı açarak sesi o cihaza yönlendirin" FontSize="12" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextDimBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,8,20,8">
                        <Button Click="OnToggleCaptureClick" Padding="12,8" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF3B82F6" Offset="0"/>
                                                <GradientStop Color="#FF06B6D4" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="{Binding CaptureButtonText}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Button>
                        <Button Click="OnRefreshClick" Margin="8,0,0,0" Padding="8" ToolTip="Cihazları Yenile" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="🔄" FontSize="16"/>
                        </Button>
                    </StackPanel>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="12,0,12,12">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="14,12" CornerRadius="10"
                                            BorderThickness="{Binding IsSelected, Converter={StaticResource SelToBorder}}"
                                            BorderBrush="{Binding IsSelected, Converter={StaticResource SelToBorderBrush}}"
                                            Cursor="Hand" MouseLeftButtonDown="OnDeviceCardClick">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="42" Height="42" Margin="0,0,12,0">
                                                <Ellipse Width="42" Height="42"
                                                         Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush>
                                                            <GradientStop Color="#3010B981" Offset="0"/>
                                                            <GradientStop Color="#0010B981" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <Border Width="36" Height="36" CornerRadius="18"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DeviceIcon}" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="170"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding DeviceTypeName}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
                                                    <TextBlock Text="  •  " FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
                                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,4,0"
                                                             Fill="{Binding IsActive, Converter={StaticResource ActiveToBrush}}"/>
                                                    <TextBlock FontSize="11" Foreground="{Binding IsActive, Converter={StaticResource ActiveToBrush}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Pasif"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Aktif"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                             VerticalAlignment="Center"
                                                             Checked="OnDeviceToggleChanged"
                                                             Unchecked="OnDeviceToggleChanged"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <Border Grid.Column="1" Background="{DynamicResource PanelBackgroundBrush}"
                    CornerRadius="16" BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" Margin="8,0,0,0" Effect="{DynamicResource CardShadow}">
                <Grid>
                    <StackPanel x:Name="WelcomePanel" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380">
                        <TextBlock Text="🎧" FontSize="56" HorizontalAlignment="Center"/>
                        <TextBlock Text="Nasıl Kullanılır?" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,16"/>
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource AccentBlueBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="1" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Cihaz Anahtarını Açın" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Sol paneldeki anahtarı açarak sesi o cihaza yönlendirin" FontSize="11" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource AccentBlueBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="2" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Cihaza Tıklayın" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ses, bass ve ekolaizer ayarlarını düzenleyin" FontSize="11" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource AccentBlueBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="3" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Birden Fazla Cihaz Açın" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Aynı anda 4 cihaza kadar ses yönlendirin" FontSize="11" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="💡 Ses yakalama, ilk cihaz açıldığında otomatik başlar" FontSize="11"
                                   Foreground="{DynamicResource AccentBlueLightBrush}" HorizontalAlignment="Center"
                                   Margin="0,16,0,0" FontStyle="Italic"/>
                    </StackPanel>
                    <ScrollViewer x:Name="ControlPanel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="24,16,24,24" DataContext="{Binding SelectedDevice}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource SurfaceBrush}">
                                    <TextBlock Text="{Binding DeviceIcon}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="12" Margin="0,2,0,0" Foreground="{DynamicResource TextDimBrush}">
                                        <Run Text="{Binding DeviceTypeName, Mode=OneWay}"/><Run Text="  •  "/><Run Text="{Binding ConnectionStatus, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                            
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="🔊  Ses Seviyesi" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBlueBrush}" Text="{Binding Volume, Converter={StaticResource VolToPercent}}"/>
                                    </Grid>
                                    <Slider Value="{Binding Volume, Mode=TwoWay}" Minimum="0" Maximum="100"
                                            TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderValueChanged"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="🎸  Bass Boost" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBlueBrush}" Text="{Binding BassBoost, Converter={StaticResource GainToStr}}"/>
                                    </Grid>
                                    <Slider Value="{Binding BassBoost, Mode=TwoWay}" Minimum="0" Maximum="12"
                                            TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="OnSliderValueChanged"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="20,16" Margin="0,0,0,12">
                                <StackPanel DataContext="{Binding Equalizer}">
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="🎚️  Ekolaizer" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Button HorizontalAlignment="Right" Click="OnResetEqClick" Cursor="Hand" Padding="8,4">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="Sıfırla" FontSize="11" Foreground="{DynamicResource AccentBlueBrush}"/>
                                        </Button>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Low" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Value="{Binding LowGain, Mode=TwoWay}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="OnSliderValueChanged" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LowGain, Converter={StaticResource GainToStr}}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource AccentBlueLightBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Mid" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Value="{Binding MidGain, Mode=TwoWay}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="OnSliderValueChanged" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding MidGain, Converter={StaticResource GainToStr}}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource AccentBlueLightBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="High" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Value="{Binding HighGain, Mode=TwoWay}" Minimum="-12" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="OnSliderValueChanged" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding HighGain, Converter={StaticResource GainToStr}}" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource AccentBlueLightBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="20,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="⏱️  Gecikme Senkronizasyonu" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBlueBrush}" Text="{Binding SyncDelayMs, Converter={StaticResource DelayToStr}}"/>
                                    </Grid>
                                    <Slider Value="{Binding SyncDelayMs, Mode=TwoWay}" Minimum="0" Maximum="200" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderValueChanged"/>
                                    <TextBlock Text="Bluetooth cihazlarının gecikme farkını dengelemek için bu değeri ayarlayın." FontSize="11" Margin="0,8,0,0" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <Border Grid.Row="2" Padding="16,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF0F1420" Offset="0"/>
                    <GradientStop Color="#FF151D30" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#10FFFFFF"/>
            </Border.BorderBrush>
            <Border.BorderThickness>0,1,0,0</Border.BorderThickness>
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Padding="10,4" Margin="0,0,4,0">
                        <TextBlock FontSize="11" Foreground="{DynamicResource AccentBlueLightBrush}" VerticalAlignment="Center">
                            <Run Text="{Binding ActiveDeviceCount, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding Devices.Count, Mode=OneWay}"/><Run Text=" Aktif"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
